<Window x:Class="ZModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ZModManager.ViewModels"
        xmlns:conv="clr-namespace:ZModManager.Converters"
        xmlns:models="clr-namespace:ZModManager.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="ZModManager"
        Icon="app_icon.png"
        Height="680" Width="1060"
        MinWidth="820" MinHeight="520"
        Background="{StaticResource BrBgMain}"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="Segoe UI" FontSize="13">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter  x:Key="InvBoolToVis" Invert="True"/>
        <conv:LogLevelToColorConverter   x:Key="LogColor"/>
        <conv:RuntimeTypeToBrushConverter x:Key="RTBrush"/>

        <!-- ── Mod enabled toggle checkbox ───────────────────────────────── -->
        <Style x:Key="ModToggle" TargetType="CheckBox">
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd"
                                Width="18" Height="18"
                                CornerRadius="4"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource BrBorderLight}"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                            <!-- Viewbox keeps the tick exactly centred and correctly scaled -->
                            <Viewbox x:Name="TickBox"
                                     Width="10" Height="10"
                                     Visibility="Collapsed"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Data="M1,5 L4,9 L10,1"
                                      Stroke="{StaticResource BrAccent}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TickBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bd"      Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                                <Setter TargetName="Bd"      Property="Background"  Value="{StaticResource BrAccentGlow}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrAccentHot}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window chrome buttons ─────────────────────────────────────── -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource BrTextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrBgCard}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseChromeBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab control ───────────────────────────────────────────────── -->
        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <TabPanel DockPanel.Dock="Top" IsItemsHost="True"/>
                            <Border Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground"      Value="{StaticResource BrTextMuted}"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer border for the 1px window edge -->
    <Border BorderBrush="{StaticResource BrBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="160" MinHeight="80" MaxHeight="300"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  Row 0 — Custom title bar                                     -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BrBgDeep}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: logo + app name -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource BrAccent}" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#7C6FF7" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                            </Border.Effect>
                        </Border>
                        <TextBlock Text="ZModManager"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource BrText}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" — " Foreground="{StaticResource BrTextDim}"
                                   VerticalAlignment="Center" Margin="2,0"/>
                        <TextBlock Text="{Binding WindowSubtitle}"
                                   FontSize="13" Foreground="{StaticResource BrTextMuted}"
                                   VerticalAlignment="Center"/>
                        <!-- Running indicator -->
                        <TextBlock Text="{Binding WindowRunningIndicator}"
                                   FontSize="11" Foreground="#44CC44"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   ToolTip="Game is running"/>
                    </StackPanel>

                    <!-- Centre: drag area -->
                    <Border Grid.Column="1" Background="Transparent"
                            shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                    <!-- Right: window controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- About button -->
                        <Button Command="{Binding OpenAboutCommand}"
                                ToolTip="About &amp; More Tools" Margin="0,0,2,0"
                                Style="{StaticResource ChromeBtn}">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,7H13V9H11V7M11,11H13V17H11V11Z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Settings button -->
                        <Button Command="{Binding OpenSettingsCommand}"
                                ToolTip="Settings" Margin="0,0,4,0"
                                Style="{StaticResource ChromeBtn}">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94
                                                l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32
                                                c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96
                                                c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81
                                                c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84
                                                c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35
                                                C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33
                                                c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87
                                                C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58
                                                C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94
                                                l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61
                                                l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22
                                                l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94
                                                l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84
                                                c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54
                                                c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96
                                                c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32
                                                c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z
                                                M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6
                                                s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource ChromeBtn}" Click="OnMinimize" ToolTip="Minimize">
                            <Path Data="M 0,6 H 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="12" Height="12" Stretch="None"/>
                        </Button>
                        <Button Style="{StaticResource ChromeBtn}" Click="OnMaximizeRestore" ToolTip="Maximize / Restore">
                            <Path Data="M 1,1 H 11 V 11 H 1 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" Fill="Transparent"
                                  Width="12" Height="12" Stretch="None"/>
                        </Button>
                        <Button Style="{StaticResource CloseChromeBtn}" Click="OnClose" ToolTip="Close">
                            <Path Data="M 1,1 L 11,11 M 11,1 L 1,11"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="12" Height="12" Stretch="None"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  Row 1 — Main content                                         -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" MinWidth="180" MaxWidth="340"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Sidebar: game list ───────────────────────────────── -->
                <Border Grid.Column="0" Background="{StaticResource BrBgSidebar}">
                    <DockPanel>
                        <!-- Footer: add / remove / detect buttons -->
                        <Border DockPanel.Dock="Bottom" Padding="10,10"
                                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource AccentButton}"
                                            Command="{Binding AddProfileCommand}"
                                            Padding="0,8" FontSize="12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="＋ " FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Text="Add Game" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Style="{StaticResource DangerButton}"
                                            Command="{Binding RemoveProfileCommand}"
                                            Padding="0,8" FontSize="13" ToolTip="Remove selected game">✕</Button>
                                </Grid>
                                <Button Style="{StaticResource GhostButton}"
                                        Command="{Binding DetectEngineCommand}"
                                        Padding="0,7" FontSize="11" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="🔍 " VerticalAlignment="Center"/>
                                        <TextBlock Text="Analyse Game Engine" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                                            Command="{Binding ExportProfileCommand}"
                                            Padding="0,6" FontSize="11"
                                            ToolTip="Export selected profile to JSON">Export</Button>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                            Command="{Binding ImportProfileCommand}"
                                            Padding="0,6" FontSize="11"
                                            ToolTip="Import a profile from JSON">Import</Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section label -->
                        <TextBlock DockPanel.Dock="Top" Text="GAMES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource BrTextDim}"
                                   Margin="16,14,16,6"/>

                        <!-- Game search -->
                        <TextBox DockPanel.Dock="Top"
                                 Text="{Binding ProfileFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="10,0,10,8" Padding="8,5" FontSize="11"
                                 ToolTip="Filter games by name"/>

                        <!-- Game list -->
                        <ListBox ItemsSource="{Binding FilteredProfiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GameProfile}">
                                    <Border Padding="14,10" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ProcessName}"
                                                           FontSize="10" Foreground="{StaticResource BrTextMuted}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="7,3"
                                                    Margin="6,0,0,0" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource BrMonoBg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RuntimeType}"
                                                                         Value="{x:Static models:RuntimeType.IL2CPP}">
                                                                <Setter Property="Background" Value="{StaticResource BrIL2CPPBg}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding RuntimeType}"
                                                                         Value="{x:Static models:RuntimeType.Unknown}">
                                                                <Setter Property="Background" Value="#16161E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding RuntimeLabel}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding RuntimeType, Converter={StaticResource RTBrush}}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Divider -->
                <Border Grid.Column="1" Background="{StaticResource BrBorder}"/>

                <!-- ── Detail panel ──────────────────────────────────────── -->
                <Grid Grid.Column="2" Background="{StaticResource BrBgMain}">

                    <!-- Empty state -->
                    <StackPanel Visibility="{Binding HasProfile, Converter={StaticResource InvBoolToVis}}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.25">
                        <TextBlock Text="No game selected" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource BrTextMuted}"/>
                        <TextBlock Text="Add a game from the sidebar"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Margin="0,6,0,0" Foreground="{StaticResource BrTextDim}"/>
                    </StackPanel>

                    <!-- Profile detail -->
                    <DockPanel Visibility="{Binding HasProfile, Converter={StaticResource BoolToVis}}">

                        <!-- ─ Game header bar ────────────────────────────── -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BrBgSidebar}"
                                BorderBrush="{StaticResource BrBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="22,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding SelectedProfile.Name}"
                                                   FontSize="18" FontWeight="Bold"/>
                                        <Border Margin="10,0,0,0" CornerRadius="5" Padding="9,3"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BrMonoBg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedProfile.RuntimeType}"
                                                                     Value="{x:Static models:RuntimeType.IL2CPP}">
                                                            <Setter Property="Background" Value="{StaticResource BrIL2CPPBg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RuntimeBadge}"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{Binding SelectedProfile.RuntimeType, Converter={StaticResource RTBrush}}"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding SelectedProfile.GameExePath}"
                                               FontSize="11" Foreground="{StaticResource BrTextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding OpenGameFolderCommand}"
                                            Margin="0,0,6,0" Padding="10,8" FontSize="12"
                                            ToolTip="Open game folder in Explorer">📁</Button>
                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding OpenModsFolderCommand}"
                                            Margin="0,0,6,0" Padding="10,8" FontSize="12"
                                            ToolTip="Open mods folder in Explorer">📂</Button>
                                    <Button Style="{StaticResource GhostButton}"
                                            Command="{Binding DetectRuntimeCommand}"
                                            Margin="0,0,6,0" Padding="12,8" FontSize="12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⟳ " FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="Detect" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Command="{Binding InjectAllCommand}"
                                            IsEnabled="{Binding IsIdle}"
                                            Margin="0,0,6,0" Padding="14,8" FontSize="12">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                <Setter Property="Content" Value="Inject All"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIL2CPPGame}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- Launch button (label varies by runtime) -->
                                    <Button Visibility="{Binding IsLaunching, Converter={StaticResource InvBoolToVis}}"
                                            Style="{StaticResource AccentButton}"
                                            Command="{Binding LaunchInjectCommand}"
                                            IsEnabled="{Binding IsIdle}"
                                            Padding="18,8" MinWidth="120">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶ " FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Launch + Inject"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIL2CPPGame}" Value="True">
                                                                <Setter Property="Text" Value="Launch"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>

                                    <!-- Launch without mods -->
                                    <Button Visibility="{Binding IsLaunching, Converter={StaticResource InvBoolToVis}}"
                                            Style="{StaticResource GhostButton}"
                                            Command="{Binding LaunchCleanCommand}"
                                            IsEnabled="{Binding IsIdle}"
                                            Padding="12,8" Margin="6,0,0,0"
                                            ToolTip="Launch game without any mods">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▷ " FontSize="13" VerticalAlignment="Center"/>
                                            <TextBlock Text="No Mods" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Cancel during launch -->
                                    <Button Visibility="{Binding IsLaunching, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding CancelLaunchCommand}"
                                            Padding="18,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="7" Height="7" CornerRadius="3.5"
                                                    Background="{StaticResource BrError}" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="Border.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.3" Duration="0:0:0.7"
                                                                                 AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                            </Border>
                                            <TextBlock Text="Cancel Launch" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ─ Scrollable content area ────────────────────── -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="22,18,22,22">

                                <!-- Runtime hint banners -->
                                <Border Visibility="{Binding IsMonoGame, Converter={StaticResource BoolToVis}}"
                                        Background="{StaticResource BrMonoBg}"
                                        BorderBrush="#1A3A5C" BorderThickness="1"
                                        CornerRadius="6" Padding="14,9" Margin="0,0,0,16">
                                    <TextBlock FontSize="12" Foreground="#88B8D8" TextWrapping="Wrap">
                                        <Run FontWeight="Bold" Foreground="{StaticResource BrMono}">Mono</Run>
                                        <Run> — each mod requires an assembly path + namespace / class / method entry point.</Run>
                                    </TextBlock>
                                </Border>

                                <!-- ═══ IL2CPP FRAMEWORK PANEL ═══════════════ -->
                                <Border Visibility="{Binding IsIL2CPPGame, Converter={StaticResource BoolToVis}}"
                                        Background="{StaticResource BrIL2CPPBg}"
                                        BorderBrush="#3A2010" BorderThickness="1"
                                        CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
                                    <StackPanel>

                                        <!-- Header row: IL2CPP label + status badge -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="12"
                                                       Foreground="#C8907A" VerticalAlignment="Center">
                                                <Run FontWeight="Bold" Foreground="{StaticResource BrIL2CPP}">IL2CPP</Run>
                                                <Run> — choose a mod framework to load mods on game start.</Run>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        Margin="10,0,0,0" VerticalAlignment="Center">

                                                <!-- ── Three-phase framework status badge ── -->
                                                <Border x:Name="FwBadge"
                                                        BorderThickness="1" CornerRadius="5" Padding="9,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Default: not installed (red) -->
                                                            <Setter Property="Background"  Value="#200808"/>
                                                            <Setter Property="BorderBrush" Value="#5a1414"/>
                                                            <Style.Triggers>
                                                                <!-- Installed: MelonLoader (green) -->
                                                                <DataTrigger Binding="{Binding DetectedFramework}"
                                                                             Value="{x:Static models:IL2CPPFramework.MelonLoader}">
                                                                    <Setter Property="Background"  Value="#081808"/>
                                                                    <Setter Property="BorderBrush" Value="#1a6a2a"/>
                                                                </DataTrigger>
                                                                <!-- Installed: BepInEx (green) -->
                                                                <DataTrigger Binding="{Binding DetectedFramework}"
                                                                             Value="{x:Static models:IL2CPPFramework.BepInEx}">
                                                                    <Setter Property="Background"  Value="#081808"/>
                                                                    <Setter Property="BorderBrush" Value="#1a6a2a"/>
                                                                </DataTrigger>
                                                                <!-- Installed: ZModBootstrap (green) -->
                                                                <DataTrigger Binding="{Binding DetectedFramework}"
                                                                             Value="{x:Static models:IL2CPPFramework.ZModBootstrap}">
                                                                    <Setter Property="Background"  Value="#081808"/>
                                                                    <Setter Property="BorderBrush" Value="#1a6a2a"/>
                                                                </DataTrigger>
                                                                <!-- Installing (orange) — highest priority, comes last -->
                                                                <DataTrigger Binding="{Binding IsInstallingFramework}"
                                                                             Value="True">
                                                                    <Setter Property="Background"  Value="#1a0e00"/>
                                                                    <Setter Property="BorderBrush" Value="#7a4400"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <StackPanel Orientation="Horizontal">
                                                        <!-- Colour dot -->
                                                        <Ellipse Width="6" Height="6"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,5,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="#cc3333"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.MelonLoader}">
                                                                            <Setter Property="Fill" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.BepInEx}">
                                                                            <Setter Property="Fill" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.ZModBootstrap}">
                                                                            <Setter Property="Fill" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsInstallingFramework}"
                                                                                     Value="True">
                                                                            <Setter Property="Fill" Value="#ff9900"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <!-- Status text -->
                                                        <TextBlock Text="{Binding FrameworkStatus}"
                                                                   FontSize="10" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="Foreground" Value="#cc3333"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.MelonLoader}">
                                                                            <Setter Property="Foreground" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.BepInEx}">
                                                                            <Setter Property="Foreground" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding DetectedFramework}"
                                                                                     Value="{x:Static models:IL2CPPFramework.ZModBootstrap}">
                                                                            <Setter Property="Foreground" Value="#44cc66"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsInstallingFramework}"
                                                                                     Value="True">
                                                                            <Setter Property="Foreground" Value="#ff9900"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Version badge (shown when installed) -->
                                                <Border Margin="6,0,0,0"
                                                        Background="#0e0e1a" BorderBrush="#2a2a40"
                                                        BorderThickness="1" CornerRadius="5" Padding="8,4"
                                                        Visibility="{Binding HasFrameworkVersion, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding FrameworkVersion}"
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="#7070c0"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Install progress (visible only while installing) -->
                                        <Border Visibility="{Binding IsInstallingFramework, Converter={StaticResource BoolToVis}}"
                                                Background="#0A1A0A" BorderBrush="#2A4A2A"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="10,6" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding FrameworkInstallProgress}"
                                                       FontSize="11" Foreground="#80C060"/>
                                        </Border>

                                        <!-- Framework buttons -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <!-- Install MelonLoader -->
                                            <Button Command="{Binding InstallMelonLoaderCommand}"
                                                    FontSize="11" Padding="10,5" Margin="0,0,8,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Content"     Value="Install MelonLoader"/>
                                                        <Setter Property="Background"  Value="#0E2A18"/>
                                                        <Setter Property="Foreground"  Value="#66CC88"/>
                                                        <Setter Property="BorderBrush" Value="#2A6040"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DetectedFramework}"
                                                                         Value="{x:Static models:IL2CPPFramework.MelonLoader}">
                                                                <Setter Property="Content"     Value="↺  Reinstall MelonLoader"/>
                                                                <Setter Property="Background"  Value="#1A1A0A"/>
                                                                <Setter Property="Foreground"  Value="#CCCC44"/>
                                                                <Setter Property="BorderBrush" Value="#4A4A20"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Install BepInEx -->
                                            <Button Command="{Binding InstallBepInExCommand}"
                                                    FontSize="11" Padding="10,5" Margin="0,0,8,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Content"     Value="Install BepInEx"/>
                                                        <Setter Property="Background"  Value="#0E1A2A"/>
                                                        <Setter Property="Foreground"  Value="#6688CC"/>
                                                        <Setter Property="BorderBrush" Value="#204060"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DetectedFramework}"
                                                                         Value="{x:Static models:IL2CPPFramework.BepInEx}">
                                                                <Setter Property="Content"     Value="↺  Reinstall BepInEx"/>
                                                                <Setter Property="Background"  Value="#1A1A0A"/>
                                                                <Setter Property="Foreground"  Value="#CCCC44"/>
                                                                <Setter Property="BorderBrush" Value="#4A4A20"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Uninstall (only shown when a framework is installed) -->
                                            <Button Content="Uninstall"
                                                    Command="{Binding UninstallFrameworkCommand}"
                                                    FontSize="11" Padding="10,5">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Background"  Value="#301010"/>
                                                        <Setter Property="Foreground"  Value="#C06060"/>
                                                        <Setter Property="BorderBrush" Value="#602020"/>
                                                        <Setter Property="Visibility"  Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DetectedFramework}"
                                                                         Value="{x:Static models:IL2CPPFramework.MelonLoader}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DetectedFramework}"
                                                                         Value="{x:Static models:IL2CPPFramework.BepInEx}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <!-- Compatibility disclaimer -->
                                        <Border Background="#1A0A00" BorderBrush="#3A2000"
                                                BorderThickness="1" CornerRadius="4" Padding="10,7">
                                            <TextBlock FontSize="11" Foreground="#AA7744"
                                                       TextWrapping="Wrap">
                                                <Run FontWeight="Bold">⚠  Mod compatibility:</Run>
                                                <Run> MelonLoader mods and BepInEx plugins are </Run>
                                                <Run FontWeight="Bold">not interchangeable.</Run>
                                                <Run> A MelonLoader mod will NOT work under BepInEx and vice-versa. Only install mods built for your chosen framework.</Run>
                                            </TextBlock>
                                        </Border>

                                    </StackPanel>
                                </Border>

                                <Border Visibility="{Binding IsUnknownRuntime, Converter={StaticResource BoolToVis}}"
                                        Background="#1A100A" BorderBrush="#4A3020" BorderThickness="1"
                                        CornerRadius="6" Padding="14,9" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="⚠  Runtime not detected"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource BrWarn}" Margin="0,0,0,4"/>
                                        <TextBlock Text="Click ⟳ Detect after pointing to the game executable."
                                                   FontSize="11" Foreground="{StaticResource BrTextMuted}"/>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ MODS SECTION ══════════════════════ -->
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,0,0,16">
                                    <StackPanel>

                                        <!-- Mods header -->
                                        <Border Padding="16,12"
                                                BorderBrush="{StaticResource BrBorder}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <StackPanel VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="MODS"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource BrTextDim}"
                                                                   VerticalAlignment="Center"/>
                                                        <Border Background="{StaticResource BrAccentGlow}"
                                                                CornerRadius="8" Padding="7,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding CurrentMods.Count}"
                                                                       FontSize="10" FontWeight="Bold"
                                                                       Foreground="{StaticResource BrAccentHot}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <!-- Running mods indicator -->
                                                    <Border Visibility="{Binding IsGameRunning, Converter={StaticResource BoolToVis}}"
                                                            Background="#0A2A0A" BorderBrush="#1A4A1A"
                                                            BorderThickness="1" CornerRadius="4"
                                                            Padding="8,4" Margin="0,6,80,0">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding RunningModsLabel}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       Foreground="#66CC66"/>
                                                            <ItemsControl ItemsSource="{Binding RunningMods}"
                                                                          Margin="0,3,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}"
                                                                                   FontSize="10"
                                                                                   Foreground="#44AA44"
                                                                                   Margin="8,1,0,0"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Style="{StaticResource AccentButton}"
                                                        Command="{Binding AddModCommand}"
                                                        Padding="14,6" FontSize="12">
                                                    ＋ Add Mod
                                                </Button>
                                            </Grid>
                                        </Border>

                                        <!-- Mod search + bulk toggle -->
                                        <Grid Margin="12,8,12,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding AllModsEnabled}"
                                                      IsThreeState="True"
                                                      Style="{StaticResource ModToggle}"
                                                      VerticalAlignment="Center"
                                                      ToolTip="Enable / disable all mods"/>
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding ModFilter, UpdateSourceTrigger=PropertyChanged}"
                                                     Padding="8,5" FontSize="11"
                                                     ToolTip="Filter mods by name"/>
                                        </Grid>

                                        <!-- Mod rows -->
                                        <StackPanel Margin="12,4,12,12">
                                            <ItemsControl ItemsSource="{Binding FilteredMods}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:ModEntry}">
                                                        <Border x:Name="ModRow"
                                                                Margin="0,0,0,4"
                                                                CornerRadius="6"
                                                                BorderThickness="1">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background"   Value="{StaticResource BrBgMain}"/>
                                                                    <Setter Property="BorderBrush"  Value="{StaticResource BrBorder}"/>
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background"  Value="{StaticResource BrBgCardHover}"/>
                                                                            <Setter Property="BorderBrush" Value="{StaticResource BrBorderLight}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <Grid Margin="12,10">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="32"/>   <!-- 0: toggle -->
                                                                    <ColumnDefinition Width="*"/>    <!-- 1: name + info -->
                                                                    <ColumnDefinition Width="Auto"/> <!-- 2: compat warning -->
                                                                    <ColumnDefinition Width="Auto"/> <!-- 3: edit -->
                                                                    <ColumnDefinition Width="6"/>
                                                                    <ColumnDefinition Width="Auto"/> <!-- 5: inject -->
                                                                    <ColumnDefinition Width="6"/>
                                                                    <ColumnDefinition Width="Auto"/> <!-- 7: remove -->
                                                                </Grid.ColumnDefinitions>

                                                                <!-- Enable/disable checkbox -->
                                                                <CheckBox Grid.Column="0"
                                                                          IsChecked="{Binding IsEnabled}"
                                                                          Style="{StaticResource ModToggle}"
                                                                          VerticalAlignment="Center"
                                                                          HorizontalAlignment="Center"/>

                                                                <!-- Name + metadata -->
                                                                <StackPanel Grid.Column="1"
                                                                            VerticalAlignment="Center"
                                                                            Margin="6,0">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontSize="13" FontWeight="SemiBold"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="{Binding DllFileName}"
                                                                                   FontFamily="Cascadia Mono, Consolas"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource BrTextMuted}"
                                                                                   Margin="0,0,10,0"
                                                                                   ToolTip="{Binding DllVersionTooltip}"/>
                                                                        <TextBlock Text="{Binding EntryPointLabel}"
                                                                                   FontFamily="Cascadia Mono, Consolas"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource BrAccentHot}"
                                                                                   Opacity="0.7"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Notes}"
                                                                               FontSize="10" FontStyle="Italic"
                                                                               Foreground="{StaticResource BrTextDim}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}"
                                                                               Margin="0,2,0,0"/>
                                                                </StackPanel>

                                                                <!-- Compatibility warning badge -->
                                                                <TextBlock Grid.Column="2"
                                                                           Text="⚠"
                                                                           FontSize="14"
                                                                           Foreground="#FFB300"
                                                                           VerticalAlignment="Center"
                                                                           Margin="4,0,6,0"
                                                                           Visibility="{Binding HasCompatibilityWarning, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock.ToolTip>
                                                                        <ToolTip Background="#1a1a2e"
                                                                                 BorderBrush="#FFB300"
                                                                                 BorderThickness="1"
                                                                                 Padding="10,7">
                                                                            <TextBlock Text="{Binding CompatibilityWarning}"
                                                                                       Foreground="#FFB300"
                                                                                       TextWrapping="Wrap"
                                                                                       MaxWidth="320"
                                                                                       FontSize="12"/>
                                                                        </ToolTip>
                                                                    </TextBlock.ToolTip>
                                                                </TextBlock>

                                                                <!-- Edit button (visible on hover) -->
                                                                <Button Grid.Column="3"
                                                                        Command="{Binding DataContext.EditModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="10,5" FontSize="11"
                                                                        ToolTip="Edit mod configuration">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                                            <Setter Property="Content"     Value="Edit"/>
                                                                            <Setter Property="Visibility"  Value="Hidden"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <!-- Inject button (hidden for IL2CPP — framework handles loading) -->
                                                                <Button Grid.Column="5"
                                                                        Command="{Binding DataContext.InjectModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        IsEnabled="{Binding DataContext.IsIdle, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Padding="10,5" FontSize="11"
                                                                        ToolTip="Inject this mod into running game">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                                                                            <Setter Property="Content" Value="Inject"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DataContext.IsIL2CPPGame, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>

                                                                <!-- Remove button (visible on hover) -->
                                                                <Button Grid.Column="7"
                                                                        Command="{Binding DataContext.RemoveModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Width="28" Height="28" Padding="0"
                                                                        ToolTip="Remove this mod">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButton}">
                                                                            <Setter Property="Content"    Value="✕"/>
                                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Empty mods placeholder -->
                                            <Border Padding="0,16">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentMods.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="No mods yet"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrTextDim}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Click ＋ Add Mod to get started"
                                                               FontSize="11" Foreground="{StaticResource BrTextDim}"
                                                               Opacity="0.6" HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>

                                <!-- ═══ LAUNCH ARGS ══════════════════════ -->
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <Border Padding="16,12"
                                                BorderBrush="{StaticResource BrBorder}"
                                                BorderThickness="0,0,0,1">
                                            <TextBlock Text="LAUNCH ARGUMENTS"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{StaticResource BrTextDim}"/>
                                        </Border>
                                        <TextBox Margin="16,10"
                                                 Text="{Binding LaunchArgs, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,6" FontSize="12"
                                                 ToolTip="Extra command-line arguments passed to the game exe on launch"/>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ SETTINGS ══════════════════════════ -->
                                <Border Background="{StaticResource BrBgCard}"
                                        BorderBrush="{StaticResource BrBorder}"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,0,0,4">
                                    <StackPanel>
                                        <Border Padding="16,12"
                                                BorderBrush="{StaticResource BrBorder}"
                                                BorderThickness="0,0,0,1">
                                            <TextBlock Text="LAUNCH SETTINGS"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="{StaticResource BrTextDim}"/>
                                        </Border>
                                        <StackPanel Margin="16,10,16,14">
                                            <CheckBox IsChecked="{Binding ConfirmBeforeLaunch}"
                                                      Content="Confirm before launching"
                                                      FontSize="12" Margin="0,0,0,8"/>
                                            <CheckBox IsChecked="{Binding MinimizeToTray}"
                                                      Content="Minimize to tray after launch"
                                                      FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  Drag splitter                                                 -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <GridSplitter Grid.Row="2" Height="5"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                          Background="{StaticResource BrBorder}" Cursor="SizeNS"/>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  Row 3 — Injector output                                      -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="3" Background="{StaticResource BrBgSidebar}"
                    BorderBrush="{StaticResource BrBorder}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1"
                            Padding="12,5">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="6" Height="6" CornerRadius="3"
                                        Background="{StaticResource BrAccent}"
                                        Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="INJECTOR OUTPUT"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BrTextDim}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource GhostButton}"
                                        Command="{Binding CopyLogCommand}"
                                        Padding="10,3" FontSize="11" Margin="0,0,4,0"
                                        ToolTip="Copy log to clipboard">Copy</Button>
                                <Button Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearLogCommand}"
                                        Padding="10,3" FontSize="11">Clear</Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="LogScroller"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}" Padding="12,4,12,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:LogEntry}">
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FormattedTime}"
                                                   FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                                   Foreground="{StaticResource BrTextDim}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Message}"
                                                   FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                                   Foreground="{Binding Level, Converter={StaticResource LogColor}}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  Row 4 — Status bar                                           -->
            <!-- ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="{StaticResource BrBgDeep}"
                    BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="14,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Activity dot -->
                        <Border x:Name="ActivityDot"
                                Width="6" Height="6" CornerRadius="3"
                                Margin="0,0,8,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource BrTextDim}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource BrAccent}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.6"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBlock Text="{Binding StatusMessage}"
                                   FontSize="11" Foreground="{StaticResource BrTextMuted}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
