<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Palette ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BrBgDeep"      Color="#0F0F12"/>
    <SolidColorBrush x:Key="BrBgMain"      Color="#13131A"/>
    <SolidColorBrush x:Key="BrBgSidebar"   Color="#17171F"/>
    <SolidColorBrush x:Key="BrBgCard"      Color="#1E1E28"/>
    <SolidColorBrush x:Key="BrBgCardHover" Color="#252532"/>
    <SolidColorBrush x:Key="BrBgSelected"  Color="#2A2A3A"/>
    <SolidColorBrush x:Key="BrBorder"      Color="#2C2C3E"/>
    <SolidColorBrush x:Key="BrBorderLight" Color="#3A3A52"/>

    <!-- Accent: electric indigo-orange -->
    <SolidColorBrush x:Key="BrAccent"      Color="#7C6FF7"/>
    <SolidColorBrush x:Key="BrAccentHot"   Color="#9C91FF"/>
    <SolidColorBrush x:Key="BrAccentGlow"  Color="#3D3870"/>

    <!-- Text -->
    <SolidColorBrush x:Key="BrText"        Color="#E8E8F0"/>
    <SolidColorBrush x:Key="BrTextMuted"   Color="#7878A0"/>
    <SolidColorBrush x:Key="BrTextDim"     Color="#4A4A6A"/>

    <!-- Runtime badges -->
    <SolidColorBrush x:Key="BrMono"        Color="#4FC3F7"/>
    <SolidColorBrush x:Key="BrMonoBg"      Color="#0D2840"/>
    <SolidColorBrush x:Key="BrIL2CPP"      Color="#FF8A65"/>
    <SolidColorBrush x:Key="BrIL2CPPBg"   Color="#2E1508"/>

    <!-- Status -->
    <SolidColorBrush x:Key="BrSuccess"     Color="#66BB6A"/>
    <SolidColorBrush x:Key="BrSuccessBg"   Color="#0D2A0F"/>
    <SolidColorBrush x:Key="BrError"       Color="#EF5350"/>
    <SolidColorBrush x:Key="BrWarn"        Color="#FFB74D"/>
    <SolidColorBrush x:Key="BrInfo"        Color="#B0B0C8"/>

    <!-- ── Typography ─────────────────────────────────────────────────────── -->
    <FontFamily x:Key="FontUI">Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- ── Base TextBlock ─────────────────────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource BrText}"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"        Value="{StaticResource BrBgDeep}"/>
        <Setter Property="Foreground"        Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="10,7"/>
        <Setter Property="FontFamily"        Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="CaretBrush"        Value="{StaticResource BrAccent}"/>
        <Setter Property="SelectionBrush"    Value="{StaticResource BrAccentGlow}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            <Setter TargetName="Root" Property="Background"  Value="#0F0F18"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BrBorderLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Accent button (primary action) ────────────────────────────────── -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource BrAccent}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="22,9"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#7C6FF7" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrAccentHot}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            <Setter Property="Effect" Value="{x:Null}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Ghost button (secondary) ──────────────────────────────────────── -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrTextMuted}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="14,7"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"   Value="{StaticResource BrBgCard}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"  Value="{StaticResource BrBorderLight}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Danger button (remove) ─────────────────────────────────────────── -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
        <Setter Property="BorderBrush" Value="#4A2020"/>
        <Setter Property="Foreground"  Value="{StaticResource BrError}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#2A1010"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrError}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.3"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default button = ghost -->
    <Style TargetType="Button" BasedOn="{StaticResource GhostButton}"/>

    <!-- ── CheckBox (global default — applies to every CheckBox in the app) ── -->
    <Style TargetType="CheckBox">
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground"               Value="{StaticResource BrText}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Box -->
                        <Border x:Name="Box"
                                Width="18" Height="18"
                                CornerRadius="5"
                                Background="#0c0c18"
                                BorderBrush="{StaticResource BrBorderLight}"
                                BorderThickness="1.5"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <!-- Checkmark -->
                                <Viewbox x:Name="Check"
                                         Width="10" Height="10"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Path Data="M2,6 L5.5,10 L12,2"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"/>
                                </Viewbox>
                                <!-- Dash — indeterminate -->
                                <Border x:Name="Dash"
                                        Width="9" Height="2"
                                        Background="White"
                                        CornerRadius="1"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Label -->
                        <ContentPresenter Margin="9,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <!-- Checked: fill with accent + show tick -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box"   Property="Background"  Value="{StaticResource BrAccent}"/>
                            <Setter TargetName="Box"   Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <!-- Indeterminate: dim fill + dash -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box"  Property="Background"  Value="{StaticResource BrAccentGlow}"/>
                            <Setter TargetName="Box"  Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                            <Setter TargetName="Dash" Property="Visibility"  Value="Visible"/>
                        </Trigger>
                        <!-- Hover: brighten border -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource BrAccentHot}"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Label ──────────────────────────────────────────────────────────── -->
    <Style TargetType="Label">
        <Setter Property="Foreground"  Value="{StaticResource BrTextMuted}"/>
        <Setter Property="FontFamily"  Value="{StaticResource FontUI}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Padding"     Value="0,0,0,4"/>
    </Style>

    <!-- ── ListBox + items ────────────────────────────────────────────────── -->
    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding"                    Value="0"/>
        <Setter Property="Margin"                     Value="0"/>
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderThickness="0" Margin="0" Padding="0">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrBgCardHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrBgSelected}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Thin scrollbar ─────────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="Width"     Value="5"/>
        <Setter Property="MinWidth"  Value="5"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Style>
                                        <Style TargetType="Thumb">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="{StaticResource BrBorderLight}"
                                                                CornerRadius="3" Opacity="0.6"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Thumb.Style>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── GridSplitter ───────────────────────────────────────────────────── -->
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource BrBorder}"/>
    </Style>

</ResourceDictionary>
