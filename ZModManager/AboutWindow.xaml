<Window x:Class="ZModManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        Width="500" Height="580"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <!-- Link button -->
        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3d6aff"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5580ff"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2a50dd"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ghost link button -->
        <Style x:Key="GhostLink" TargetType="Button" BasedOn="{StaticResource LinkBtn}">
            <Setter Property="Background" Value="#20ffffff"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#35ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tag pill -->
        <Style x:Key="Tag" TargetType="Border">
            <Setter Property="Background"     Value="#1e2040"/>
            <Setter Property="CornerRadius"   Value="10"/>
            <Setter Property="Padding"        Value="8,3"/>
            <Setter Property="Margin"         Value="0,0,5,0"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="#D8101020"
            BorderBrush="#40ffffff"
            BorderThickness="1"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.6"
                              BlurRadius="32" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                    Background="#18182e"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid Margin="16,0">
                    <TextBlock Text="About ZModManager" Foreground="#d0d0f0"
                               FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Width="32" Height="32"
                            Content="✕" Foreground="#888" FontSize="13"
                            Click="OnClose">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c0392b"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom" Fill="#25254a"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,12">

                    <!-- App identity -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Image Source="app_icon.png" Width="48" Height="48"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ZModManager" FontSize="22"
                                       FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Game mod manager &amp; injector for Unity games"
                                       Foreground="#6060a0" FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock Text="by TheHolyOneZ" Foreground="#3d6aff"
                                       FontSize="11" Margin="0,3,0,0" Cursor="Hand"
                                       MouseLeftButtonDown="OpenZLogic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="#1e1e38" Margin="0,16,0,16"/>

                    <!-- Section header -->
                    <TextBlock Text="MORE BY THEHOLYONEZ"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4a4a7a" Margin="0,0,0,12"/>

                    <!-- ── Card 1: ZLogic.eu ───────────────────────────── -->
                    <Border Background="#12122a" CornerRadius="10"
                            BorderBrush="#25254a" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎮" FontSize="16" Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="ZLogic.eu — Mod Menu Portal"
                                               Foreground="White" FontWeight="SemiBold"
                                               FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="Browse and download free, regularly updated mod menus for 10+ PC games — HollowKnight, PEAK, Subnautica, Raft and more. Trusted by 5,800+ downloads."
                                       Foreground="#8888aa" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,8,0,10"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Free" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="10+ Games" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Regularly Updated" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Row="3" Style="{StaticResource LinkBtn}"
                                    Content="Visit zlogic.eu →" HorizontalAlignment="Left"
                                    Click="OpenZLogic"/>
                        </Grid>
                    </Border>

                    <!-- ── Card 2: SharpMonoInjector ──────────────────── -->
                    <Border Background="#12122a" CornerRadius="10"
                            BorderBrush="#25254a" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="💉" FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="SharpMonoInjector TheHolyOneZ Edition"
                                           Foreground="White" FontWeight="SemiBold"
                                           FontSize="14" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Text="A modern, fully-featured Mono assembly injector for Unity games. Stealth mode, hot-reload, profile system, assembly inspector and a clean dark UI — built for power users and researchers."
                                       Foreground="#8888aa" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,8,0,10"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Stealth Mode" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Hot-Reload" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Open Source" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Row="3" Style="{StaticResource LinkBtn}"
                                    Content="View on GitHub →" HorizontalAlignment="Left"
                                    Click="OpenSharpMonoInjector"/>
                        </Grid>
                    </Border>

                    <!-- ── Card 3: Zoryx Discord Bot Framework ────────── -->
                    <Border Background="#12122a" CornerRadius="10"
                            BorderBrush="#25254a" BorderThickness="1"
                            Padding="16,14" Margin="0,0,0,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="🤖" FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Zoryx Discord Bot Framework"
                                           Foreground="White" FontWeight="SemiBold"
                                           FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1"
                                       Text="Production-ready Python framework for building advanced Discord bots. Hot-reload extensions, per-guild SQLite databases, web monitoring dashboard, AI assistant and enterprise-grade architecture."
                                       Foreground="#8888aa" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,8,0,10"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Hot-Reload" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="AI Powered" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                                <Border Style="{StaticResource Tag}">
                                    <TextBlock Text="Production Ready" Foreground="#6ea8fe" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Orientation="Horizontal">
                                <Button Style="{StaticResource LinkBtn}"
                                        Content="Website →" Margin="0,0,8,0"
                                        Click="OpenZDBFSite"/>
                                <Button Style="{StaticResource GhostLink}"
                                        Content="GitHub" Click="OpenZDBFGitHub"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14"
                    Background="#14142a"
                    BorderBrush="#25254a" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#3a3a60" FontSize="11">
                        <Run Text="Made with ♥ by "/>
                        <Run Text="TheHolyOneZ" Foreground="#3d6aff" Cursor="Hand"
                             MouseLeftButtonDown="OpenZLogic"/>
                    </TextBlock>
                    <Button Style="{StaticResource LinkBtn}" Content="Close"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="OnClose"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
