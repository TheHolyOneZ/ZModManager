<Window x:Class="ZModManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ZModManager.Models"
        Title="Settings"
        Width="460" Height="430"
        MinWidth="420" MinHeight="380"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>

        <!-- ── Dark ComboBox ───────────────────────────────────────────────── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1a1a2e"/>
            <Setter Property="Foreground"      Value="#c8c8dc"/>
            <Setter Property="BorderBrush"     Value="#2d2d50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid Margin="10,0,8,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Margin="0,0,20,0"/>
                                    <Path HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 5 5 L 10 0 Z"
                                          Fill="#6060a0"/>
                                </Grid>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                          Opacity="0" Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="#1a1a2e"
                                        BorderBrush="#3d3d60"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.5"
                                                          BlurRadius="16" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5555a0"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3d6aff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="#c8c8dc"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding"    Value="12,7"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#252540"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2d3a70"/>
                                        <Setter Property="Foreground" Value="#ffffff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- ── Done button ─────────────────────────────────────────────────── -->
        <Style x:Key="DoneBtn" TargetType="Button">
            <Setter Property="Background"      Value="#3d6aff"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="28,9"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5580ff"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#2a50dd"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <!-- Outer container — rounded, semi-transparent, glowing border -->
    <Border CornerRadius="14"
            Background="#D8101020"
            BorderBrush="#40ffffff"
            BorderThickness="1"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.6"
                              BlurRadius="32" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>   <!-- title bar -->
                <RowDefinition Height="*"/>    <!-- content -->
                <RowDefinition Height="60"/>   <!-- footer -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0"
                    Background="#18182e"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="14" Foreground="#5566cc" Margin="0,0,8,0"/>
                        <TextBlock Text="Settings" Foreground="#d0d0f0"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right"
                            Width="32" Height="32"
                            Content="✕"
                            Foreground="#888"
                            FontSize="13"
                            Click="OnClose">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="0">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c0392b"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Divider -->
            <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                        Fill="#25254a"/>

            <!-- Content -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,12,24,4">
                <StackPanel>

                    <!-- ── LAUNCH BEHAVIOUR ──────────────────────────────── -->
                    <TextBlock Text="LAUNCH BEHAVIOUR"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4a4a7a" Margin="0,12,0,10"/>

                    <StackPanel Margin="0,0,0,10">
                        <CheckBox IsChecked="{Binding ConfirmBeforeLaunch}"
                                  Content="Ask for confirmation before launching"/>
                        <TextBlock Text="Shows a Yes / No dialog before starting the game."
                                   Margin="22,3,0,0" FontSize="11" Foreground="#4a4a6a"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,4">
                        <CheckBox IsChecked="{Binding MinimizeToTray}"
                                  Content="Minimize to system tray after launch"/>
                        <TextBlock Text="Hides the window when the game starts. Double-click the tray icon to reopen."
                                   Margin="22,3,0,0" FontSize="11" Foreground="#4a4a6a"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="#1e1e38" Margin="0,16,0,0"/>

                    <!-- ── MOD BEHAVIOUR ──────────────────────────────────── -->
                    <TextBlock Text="MOD BEHAVIOUR"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4a4a7a" Margin="0,14,0,10"/>

                    <StackPanel Margin="0,0,0,4">
                        <CheckBox IsChecked="{Binding AutoDisableIncompat}"
                                  Content="Auto-disable incompatible mods on launch"/>
                        <TextBlock Text="If a mod targets a different framework than what's installed it gets disabled automatically before the game starts."
                                   Margin="22,3,0,0" FontSize="11" Foreground="#4a4a6a"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="#1e1e38" Margin="0,16,0,0"/>

                    <!-- ── IL2CPP DEFAULTS ─────────────────────────────────── -->
                    <TextBlock Text="IL2CPP DEFAULTS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#4a4a7a" Margin="0,14,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Preferred framework" Foreground="#c8c8dc"/>
                            <TextBlock Text="Used when installing a new IL2CPP framework."
                                       FontSize="11" Foreground="#4a4a6a" Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource DarkCombo}"
                                  VerticalAlignment="Center"
                                  SelectedValue="{Binding DefaultIL2CPPFramework}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="MelonLoader"
                                          Tag="{x:Static models:IL2CPPFramework.MelonLoader}"/>
                            <ComboBoxItem Content="BepInEx"
                                          Tag="{x:Static models:IL2CPPFramework.BepInEx}"/>
                        </ComboBox>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14"
                    Background="#14142a"
                    BorderBrush="#25254a" BorderThickness="0,1,0,0">
                <Button Style="{StaticResource DoneBtn}"
                        Content="Done"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0"
                        Click="OnClose"/>
            </Border>

        </Grid>
    </Border>
</Window>
